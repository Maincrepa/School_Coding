<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="18"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.lasalle.hadivina.adivina.HelloController"
      style="-fx-background-color: linear-gradient(to bottom, #667eea 0%, #764ba2 100%);">

    <padding>
        <Insets top="28" right="28" bottom="28" left="28"/>
    </padding>

    <Label text="ADIVINA EL NÚMERO"
           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>

    <Label fx:id="lblIntentos"
           text="Tienes 5 intentos"
           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #FFD700;"/>

    <Label fx:id="lblPista"
           text="Piensa un número entre 1 y 50"
           wrapText="true"
           maxWidth="360"
           alignment="CENTER"
           style="-fx-font-size: 18px; -fx-text-fill: white; -fx-background-color: rgba(0,0,0,0.30);
                  -fx-padding: 15; -fx-background-radius: 10;"/>

    <TextField fx:id="txtNumero"
               promptText="Tu número..."
               maxWidth="220"
               alignment="CENTER"
               onAction="#onAdivinar"
               style="-fx-font-size: 20px; -fx-background-radius: 10; -fx-padding: 10;"/>

    <Button fx:id="btnAdivinar"
            text="ADIVINAR"
            onAction="#onAdivinar"
            style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-background-color: #27AE60;
                   -fx-text-fill: white; -fx-padding: 12 30; -fx-background-radius: 10;"/>

    <Button fx:id="btnNuevoJuego"
            text="NUEVO JUEGO"
            onAction="#onNuevoJuego"
            visible="false"
            style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-background-color: #3498DB;
                   -fx-text-fill: white; -fx-padding: 10 20; -fx-background-radius: 10;"/>

</VBox>
